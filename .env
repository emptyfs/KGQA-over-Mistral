PACKAGE_NAME="KGQA-service"
DESCRIPTION="KGQA system on Mistral-7B"
VERSION=0.0.0
PORT=42424

NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password
NEO4J_DATABASE=neo4j

SCRIPT_NAME=app.py
MAINTAINER="pupupun"
DEPENDENCIES="coreutils, curl, gawk | mawk, grep, iproute2, jq, procps, systemd | systemctl"
DEPENDENCIES="${DEPENDENCIES}, python3 (>= 3.10), python3-venv (>= 3.10), python3-pip (>= 20.0~)"